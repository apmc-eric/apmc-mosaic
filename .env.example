# Copy to .env.local and fill in. Never commit .env.local.

# --- Required (browser + server Supabase client) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# --- Server-only (admin APIs, migrations) ---
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
POSTGRES_URL_NON_POOLING=postgresql://...  # scripts/run-migration.js

# --- Optional ---
NEXT_PUBLIC_ALLOW_DEV_LOGIN=false
ALLOW_DEV_LOGIN=false

# Google Calendar (server routes under app/api/calendar/) — **must** match Supabase Auth → Providers → Google
# (same OAuth client ID + secret). If they differ, stored refresh tokens cannot be exchanged and Calendar returns 401.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ScreenshotOne (app/api/screenshot)
SCREENSHOTONE_ACCESS_KEY=
SCREENSHOTONE_SECRET_KEY=

# Capture pipeline (app/api/capture)
PUPPETEER_EXECUTABLE_PATH=
USE_SELF_HOSTED_CAPTURE=
